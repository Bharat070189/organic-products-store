{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An organic product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "stock", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "shipping": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["cod", "online"] },
        "createdAt": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["customerName", "customerEmail", "items", "total", "status", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "A discount promo code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minOrderAmount": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["code", "discountType", "discountValue"]
    },
    "Banner": {
      "title": "Banner",
      "description": "A homepage banner",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "link": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["imageUrl", "isActive"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "shippingCharge": { "type": "number" },
        "minOrderForFreeShipping": { "type": "number" },
        "lowStockThreshold": { "type": "number" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback or contact messages",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Organic products catalog" },
    "/orders": { "schema": "Order", "description": "Customer orders" },
    "/categories": { "schema": "Category", "description": "Product categories" },
    "/promocodes": { "schema": "PromoCode", "description": "Discount codes" },
    "/banners": { "schema": "Banner", "description": "Homepage banners" },
    "/settings/app": { "schema": "AppSettings", "description": "Global app settings" },
    "/feedback": { "schema": "Feedback", "description": "User contact messages" },
    "/profiles": { "schema": "Profile", "description": "User profiles" }
  }
}
